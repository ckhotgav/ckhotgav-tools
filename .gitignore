# ============================================
#  安全與隱私 — 絕不提交個人資料
# ============================================

# 環境變數（可能含 API Key、密碼、Token）
.env
.env.*
.envrc
*.env.local
*.env.production
*.env.development

# NotebookLM 個人資料（筆記、來源、輸出）
notebooklm-export/
*.nlm
nlm-export/

# API Key、Token、憑證、機密
*.token
*.secret
*.key
*.pem
*.p12
*.pfx
*.cert
*.crt
*credentials*
*credential*
*cred*
*secret_key*
*api_key*
*apikey*
*.service_account.json
firebase-service-account.json
client_secret*.json

# MCP 設定（可能含路徑與個人資訊）
mcp.json
mcp*.json
.mcp*
opencode.json
opencode.jsonc
antigravity.json
*.mcp.json

# OAuth / 登入狀態
.clasprc.json
.clasprc*.json
.netlify/auth.json
.netlify/state.json
.vercel/auth.json

# Cloudflare Wrangler (安全隔離防護)
.wrangler/
wrangler.toml
wrangler.jsonc
.gh-auth*
*.auth
*oauth*
*oauth2*

# SSH / GPG
id_rsa*
id_ecdsa*
id_ed25519*
*.pub
known_hosts
authorized_keys
*.gpg
*.asc
secring.*
trustdb.*

# npm / pip / 套件登入
.npmrc
.yarnrc
.pypirc
.pip/
.netrc
.nuget/
gem/credentials

