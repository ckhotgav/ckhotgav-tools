dist/
build/
out/
release/
*.tsbuildinfo
.next/
.nuxt/
.cache/

# 依賴
node_modules/
.pnp/
.pnp.js
vendor/bundle/
.venv/
venv/
virtualenv/

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
.eggs/
pip-log.txt
pip-delete-this-directory.txt
.tox/
.mypy_cache/
.ruff_cache/

